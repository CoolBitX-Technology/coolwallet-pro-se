<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<!-- Source is the root of host-sim -->
	<classpathentry kind="src" path=""/>
	
	<!-- Java 8 JRE -->
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER/org.eclipse.jdt.internal.debug.ui.launcher.StandardVMType/JavaSE-1.8">
		<accessrules>
			<accessrule kind="accessible" pattern="com/sun/net/httpserver/**"/>
		</accessrules>
	</classpathentry>

	<!-- Depend on the main project to access coolbitx.* classes -->
	<classpathentry combineaccessrules="false" kind="src" path="/CoolWalletS_3rd"/>

	<!-- Host-side simulator / crypto libraries -->
	<classpathentry kind="lib" path="../lib/jcardsim-3.0.5-20230313.131323-6.jar"/>
	<classpathentry kind="lib" path="../local_lib/javacard-libs/bcprov-jdk15on-1.70.jar"/>

	<!-- Output folder for simulator -->
	<classpathentry kind="output" path="bin-sim"/>
</classpath>
