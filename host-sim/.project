<?xml version="1.0" encoding="UTF-8"?>
<projectDescription>
	<name>CoolWalletS_Sim</name>
	<comment>
		Cursor / VS Code IDE project for this repository.
		Used together with `coolwallet.code-workspace` so that JDT.LS uses
		this self-contained project instead of the root `.project`
		(which is reserved for the Windows Eclipse + NXP JCOP CAP workflow).
		The applet sources under `../src` are exposed via a linked resource
		called `src-main` so they show up as part of this project.
	</comment>
	<projects>
	</projects>
	<buildSpec>
		<buildCommand>
			<name>org.eclipse.jdt.core.javabuilder</name>
			<arguments>
			</arguments>
		</buildCommand>
	</buildSpec>
	<natures>
		<nature>org.eclipse.jdt.core.javanature</nature>
	</natures>
	<linkedResources>
		<link>
			<name>src-main</name>
			<type>2</type>
			<locationURI>PARENT-1-PROJECT_LOC/src</locationURI>
		</link>
	</linkedResources>
</projectDescription>
