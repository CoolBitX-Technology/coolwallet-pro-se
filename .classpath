<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<!-- Source files -->
	<classpathentry kind="src" path="src"/>
	<!-- JCOP SDK container for Windows Eclipse CAP generation -->
	<classpathentry kind="con" path="com.nxp.id.jcop.eclipse.containers.cardconfig/com.nxp.id.jcop.eclipse.cardconfigs.custom;com.nxp.id.jcop.eclipse.cardapis.jc305;com.nxp.id.jcop.eclipse.cardapis.gp230;com.nxp.id.jcop.eclipse.cardapis.R1.1.4"/>
	<!-- Host-side simulation / tools (output to a different folder so JCOP doesn't try to build it into CAP) -->
	<classpathentry kind="src" path="host-sim" output="bin-sim"/>

	<!-- JRE (Java 8) -->
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER/org.eclipse.jdt.internal.debug.ui.launcher.StandardVMType/JavaSE-1.8">
		<accessrules>
			<accessrule kind="accessible" pattern="com/sun/net/httpserver/**"/>
		</accessrules>
	</classpathentry>

	<!-- Local JavaCard / JCOP libraries (from local_lib, not committed to git) -->
	<classpathentry kind="lib" path="local_lib/javacard-libs/api_classic.jar"/>
	<classpathentry kind="lib" path="local_lib/javacard-libs/JCOPx_API-R1.1.4.jar"/>

	<!-- Host-side simulator / crypto libraries -->
	<!-- jcardsim: public jar, committed under lib/ -->
	<classpathentry kind="lib" path="lib/jcardsim-3.0.5-20230313.131323-6.jar"/>
	<!-- bcprov: fetched via Gradle into local_lib (ignored by git) -->
	<classpathentry kind="lib" path="local_lib/javacard-libs/bcprov-jdk15on-1.70.jar"/>

	<!-- Output folder -->
	<classpathentry kind="output" path="bin"/>
</classpath>
