{
    // 使用 Java 8 做為預設 JDK（請依照你實際的路徑調整）
    "java.configuration.runtimes": [
        {
            "name": "JavaSE-1.8",
            "path": "/Library/Java/JavaVirtualMachines/zulu-8.jdk/Contents/Home",
            "default": true
        }
    ],
    // 告訴 Java 擴充套件：這個專案的 source 在哪裡、class 輸出到哪裡
    "java.project.sourcePaths": [
        "src",
        "host-sim"
    ],
    "java.project.outputPath": "bin",
    // 讓 IDE 認得 JavaCard / JCOP 的 jar（由 setup-libs.sh 產生）
    "java.project.referencedLibraries": [
        "local_lib/javacard-libs/**/*.jar"
    ],
    // 一般編輯偏好
    "java.compile.nullAnalysis.mode": "disabled",
    "java.format.enabled": true,
    "editor.formatOnSave": true,
    // 避免自動幫你亂改 import（例如改成 javax.rmi.CORBA.Util）
    "java.saveActions.organizeImports": false,
    // 強制不要當成 Gradle/Maven 專案，改用一般 Java 專案模式
    "java.import.gradle.enabled": false,
    "java.import.maven.enabled": false
}